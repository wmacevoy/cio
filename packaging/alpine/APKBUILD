# Maintainer: Warren MacEvoy <wmacevoy@gmail.com>
pkgname=libcio
pkgver=1.0.0
pkgrel=0
pkgdesc="Lightweight abstract character I/O library for C"
url="https://github.com/wmacevoy/cio"
arch="all"
license="MIT"
makedepends="cmake libutf8-dev"
subpackages="$pkgname-dev $pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/wmacevoy/cio/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/cio-$pkgver"

build() {
	cmake -B build \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

check() {
	cd build
	ctest --output-on-failure
}

package() {
	cmake --install build --prefix "$pkgdir/usr"
}

# Update after creating release tarball:
#   sha512sum v1.0.0.tar.gz
sha512sums="PLACEHOLDER"
